#!/usr/bin/env bash
set -euxo pipefail

export PATH="$HOME/.local/bin:$PATH"

# Install uv for dependency resolution
curl -LsSf https://astral.sh/uv/install.sh | sh

# Install the project from the repo root
uv pip install --system -e .

# Optional Jupyter tweak
jupyter labextension enable @jupyterlab/notebook-extension:tracker || true
